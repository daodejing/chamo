# =============================================================================
# Frontend Build Configuration - Local k3d Environment
# =============================================================================
# These variables are baked into the Next.js build at compile time.
# Used by: scripts/local-lab.sh build
#
# Copy this file to .env.local for local builds:
#   cp docker/frontend/.env.local.example docker/frontend/.env.local
# =============================================================================

NEXT_PUBLIC_GRAPHQL_HTTP_URL=http://api.ourchat.localhost/graphql
NEXT_PUBLIC_GRAPHQL_WS_URL=ws://api.ourchat.localhost/graphql
