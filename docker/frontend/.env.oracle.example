# =============================================================================
# Frontend Build Configuration - Oracle Cloud Environment
# =============================================================================
# These variables are baked into the Next.js build at compile time.
# Used by: scripts/oracle-lab.sh build-push
#
# Copy this file to .env.oracle for Oracle builds:
#   cp docker/frontend/.env.oracle.example docker/frontend/.env.oracle
#
# Update the domain to match your Oracle Load Balancer IP.
# Current format: https://api.ourchat.<LB-IP-WITH-DASHES>.nip.io
# =============================================================================

NEXT_PUBLIC_GRAPHQL_HTTP_URL=https://api.ourchat.138-2-48-165.nip.io/graphql
NEXT_PUBLIC_GRAPHQL_WS_URL=wss://api.ourchat.138-2-48-165.nip.io/graphql
