# Database
DATABASE_URL="postgresql://user:password@localhost:5432/database_name?schema=public"

# JWT
JWT_SECRET=your-jwt-secret-here-use-openssl-rand-base64-32
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-secret-here-use-openssl-rand-base64-32
REFRESH_TOKEN_EXPIRES_IN=30d

# Redis (Upstash) - Optional for MVP
REDIS_URL=

# Cloudflare R2 - Optional for MVP
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ourchat-photos
R2_PUBLIC_URL=

# Google OAuth (for Calendar) - Optional
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (SMTP) - Required
# Local dev: use mailhog (no auth needed)
#   SMTP_HOST=localhost
#   SMTP_PORT=1025
# Production: use Brevo SMTP or any SMTP provider
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_USER=your-brevo-login-email
#   SMTP_PASS=your-brevo-smtp-key (from Brevo → SMTP & API → SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
# SMTP_USER=  # Only needed for authenticated SMTP (production)
# SMTP_PASS=  # Only needed for authenticated SMTP (production)
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=OurChat
EMAIL_VERIFICATION_URL=http://localhost:3002/verify-email

# Security - Email-Bound Invite Encryption (Required for Story 1.5)
# Generate with: openssl rand -hex 32
# IMPORTANT: This is SERVER-SIDE ONLY. Do NOT share with frontend.
# Used for AES-256-GCM encryption of invitee emails in database
INVITE_SECRET=your-64-character-hex-string-here

# Server
PORT=4000
NODE_ENV=development

# CORS - Allowed Origins (comma-separated, REQUIRED)
# Local dev: keep ONLY localhost (matches Next.js dev server)
CORS_ALLOWED_ORIGINS=http://localhost:3002
# Staging example (Render backend + Cloudflare Pages)
# CORS_ALLOWED_ORIGINS=https://chamo-6b9.pages.dev,http://localhost:3002
# Production example (custom domain)
# CORS_ALLOWED_ORIGINS=https://ourchat.example.com,http://localhost:3002
